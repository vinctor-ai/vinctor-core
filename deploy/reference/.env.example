# Reference-topology configuration template (PKA-33).
# Copy to `.env` and fill in. NEVER commit `.env`.
#
# This file holds NON-SECRET config plus the Postgres password. Vinctor
# workspace, agent, and operator keys are NOT configured here — they are minted
# through the operator CLI after first boot and handed to callers out-of-band.
# Do not add any raw workspace key, agent key, or grant ref to this file.

# Public hostname Caddy serves and requests certificates for. Use `localhost`
# for local testing (Caddy issues from its internal CA; clients need `-k` or the
# local root trusted). Use a real DNS name in production for automatic ACME.
VINCTOR_PUBLIC_HOSTNAME=localhost

# Edge ports published by Caddy.
VINCTOR_HTTP_PORT=80
VINCTOR_HTTPS_PORT=443

# Postgres control-plane store.
POSTGRES_USER=vinctor
POSTGRES_DB=vinctor
# Required. Generate a DSN-safe value, e.g. `openssl rand -hex 32`. Avoid
# base64: it can contain `/` and `+`, which break the interpolated libpq/psycopg
# connection string unless percent-encoded.
POSTGRES_PASSWORD=

# Service runtime.
VINCTOR_LOG_LEVEL=info

# Availability guard: max requests per source per minute (fixed window,
# fail-open). Trust ONLY the compose network subnet as a proxy so the real
# client is resolved from X-Forwarded-For. Must match the compose `vinctor-net`
# subnet; change both together.
VINCTOR_RATE_LIMIT_PER_MINUTE=600
VINCTOR_TRUSTED_PROXIES=172.28.0.0/16
